        title=&quot;javascript&quot;
        src=&quot;/static/088e4203cb6e772dc35a01bde853408d/e41a8/javascript.jpg&quot;
        srcset=&quot;/static/088e4203cb6e772dc35a01bde853408d/f93b5/javascript.jpg 300w,
/static/088e4203cb6e772dc35a01bde853408d/e41a8/javascript.jpg 460w&quot;
        sizes=&quot;(max-width: 460px) 100vw, 460px&quot;
